# ===== Un solo archivo .env en la raíz (copialo como .env y completá los valores) =====

# Puerto del servidor (Hostinger suele asignar PORT automático)
PORT=3001

# ----- LLM (uno u otro, o ambos; el agente usa el que esté definido) -----
# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
# Google Gemini: https://aistudio.google.com/apikey
GEMINI_API_KEY=...
# Opcional: forzar proveedor "openai" o "gemini" (si no, se usa el que tenga key)
# LLM_PROVIDER=gemini

# ----- WhatsApp (Twilio) -----
# Cuenta: https://console.twilio.com | WhatsApp Sandbox: https://console.twilio.com/us1/develop/sms/senders/whatsapp-sandbox
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ----- Opcional (solo si desplegás front y back por separado) -----
# URL del frontend para CORS y links; si front y back están en la misma URL, no hace falta
# FRONTEND_URL=https://tu-dominio.com
